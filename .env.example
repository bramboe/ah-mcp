# ah-mcp environment variables
# Copy this file to .env and fill in any values you want to override.
# All variables have sensible defaults for local stdio use — no configuration
# is required to get started.

# -----------------------------------------------------------------------------
# AH_CALLBACK_HOST
#   Base URL the OAuth proxy listens on. The user opens this URL in their
#   browser to complete the login flow.
#   Default: http://localhost:9876
#   Override for remote deployments: https://ah-mcp.example.com
# -----------------------------------------------------------------------------
# AH_CALLBACK_HOST=http://localhost:9876

# -----------------------------------------------------------------------------
# AH_CALLBACK_PORT
#   Port the temporary OAuth reverse-proxy server binds to during login.
#   Must match the port in AH_CALLBACK_HOST for local deployments.
#   Default: 9876
# -----------------------------------------------------------------------------
# AH_CALLBACK_PORT=9876

# -----------------------------------------------------------------------------
# AH_MCP_PORT
#   Port for the MCP HTTP/SSE server (--transport sse mode only).
#   Default: 3000
# -----------------------------------------------------------------------------
# AH_MCP_PORT=3000

# -----------------------------------------------------------------------------
# AH_TOKENS_PATH
#   Override the default XDG-compliant path for tokens.json.
#   Default (Linux):  ~/.config/ah-mcp/tokens.json
#   Default (macOS):  ~/Library/Application Support/ah-mcp/tokens.json
#   Default (Windows): %AppData%\ah-mcp\tokens.json
#   The directory is created automatically with mode 0700 if it does not exist.
#   The file is written with mode 0600 (owner read/write only).
# -----------------------------------------------------------------------------
# AH_TOKENS_PATH=/home/ah-mcp/.config/ah-mcp/tokens.json

# -----------------------------------------------------------------------------
# AH_MCP_BASE_URL
#   Base URL advertised to MCP clients for the SSE endpoint.
#   Default: http://localhost:AH_MCP_PORT  (suitable for local use)
#   Override for remote deployments behind a reverse proxy:
#   e.g. https://ah-mcp.example.com
# -----------------------------------------------------------------------------
# AH_MCP_BASE_URL=https://ah-mcp.example.com
